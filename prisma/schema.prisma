generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  phone         String?
  company       String?
  avatar        String?
  role          String    @default("user") // "user" | "admin"
  status        String    @default("active") // "active" | "suspended"
  locale        String    @default("en") // "en" | "sw"
  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  subscriptions    Subscription[]
  contactMessages  ContactMessage[]
  payments         Payment[]
  notifications    Notification[]
}

model Package {
  id             String   @id @default(cuid())
  category       String   // "starter" | "business" | "premium"
  tier           String   // "silver" | "bronze" | "gold" | "ruby"
  name           String   // Display name
  maxPhoneNumbers Int     // Max phone numbers for RBT
  features       String   // JSON string of features
  price3mo       Int      // Price for 3 months in TZS
  price6mo       Int      // Price for 6 months in TZS
  price12mo      Int      // Price for 12 months in TZS
  popular        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  subscriptions  Subscription[]
  payments       Payment[]
}

model Subscription {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  packageId    String
  package      Package           @relation(fields: [packageId], references: [id])
  billingCycle String            // "3mo" | "6mo" | "12mo"
  status       String            @default("active") // "active" | "pending" | "cancelled" | "expired"
  adminNotes   String?
  startDate    DateTime          @default(now())
  endDate      DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  numbers      AssignedNumber[]
  payments     Payment[]
}

model AssignedNumber {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  phoneNumber    String
  toneName       String?
  toneCategory   String?      // "music" | "ad" | "message" | "promo"
  status         String       @default("active") // "active" | "inactive" | "pending"
  assignedAt     DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ContactMessage {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  message    String
  status     String   @default("open") // "open" | "in_progress" | "resolved" | "closed"
  adminReply String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Payment {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  amount          Int          // Amount in TZS
  currency        String       @default("TZS")
  billingCycle    String       // "3mo" | "6mo" | "12mo"
  packageId       String
  package         Package      @relation(fields: [packageId], references: [id])
  status          String       @default("pending") // "pending" | "completed" | "failed" | "refunded"
  pesapalTrackingId String?   // PesaPal tracking ID
  pesapalOrderId  String?     // Our internal order ID sent to PesaPal
  pesapalNotificationId String? // IPN notification ID
  paymentMethod   String?     // "mpesa" | "tigopesa" | "airtel" | "visa" | "mastercard"
  phoneUsed       String?     // Phone number used for payment
  failureReason   String?
  refundedAt      DateTime?
  refundReason    String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // Admin who performed the action
  userName  String?  // Denormalized for quick display
  action    String   // "create" | "update" | "delete" | "login" | "payment" | etc.
  entity    String   // "user" | "subscription" | "package" | "number" | "payment" | "message"
  entityId  String?  // ID of the affected entity
  details   String?  // JSON string with change details
  ipAddress String?
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String   @default("info")  // info, success, warning, error
  category    String   @default("general") // payment, subscription, system, support
  isRead      Boolean  @default(false)
  actionUrl   String?  // URL to navigate to when clicked
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String?

  @@index([key])
}
